<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootCardView"
    style="@style/BaseCard"
    tools:layout_width="180dp">

    <LinearLayout
        android:id="@+id/groupLinearLayout"
        style="@style/Clickable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"

        >

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginStart="14dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="14dp"
            android:orientation="horizontal">

            <View
                android:id="@+id/turnOnLightButton"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginEnd="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/light_button_pressed"
                android:padding="12dp" />

            <View
                android:id="@+id/turnOffLightButton"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/light_button_normal"
                android:padding="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="14dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/headerTextView"
                style="@style/Text"
                android:layout_gravity="start"
                android:textAlignment="center"
                tools:text="Коридор" />

            <TextView
                android:id="@+id/secondaryTextView"
                style="@style/Text.Secondary"
                android:layout_gravity="start"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:lines="2"
                tools:text="Коридор и Прихожая" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>